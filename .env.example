# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=barbershop_db

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Session (cambia esto en producción por algo aleatorio largo) ──
SESSION_SECRET=cambia_esto_por_algo_muy_secreto_en_produccion

# ── Email (notificaciones a barberos) ─────────────────────────
# Opción 1: Gmail con App Password (recomendado)
EMAIL_SERVICE=gmail
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx   # App Password de Google (no tu contraseña normal)
#
# Para crear un App Password de Gmail:
#   1. Activa verificación en 2 pasos en tu cuenta Google
#   2. Ve a: https://myaccount.google.com/apppasswords
#   3. Crea una App Password para "Correo" → "Otro dispositivo"
#   4. Usa esa contraseña de 16 dígitos aquí
#
# Opción 2: SMTP personalizado (Outlook, Yahoo, hosting propio)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# EMAIL_USER=tucorreo@outlook.com
# EMAIL_PASS=tu_password
